<?xml version="1.0" encoding="UTF-8"?>
<!--
  SITEMAP
  Tells search engines every page on the site and roughly how often each
  changes, so they can crawl efficiently. Update this whenever a page is
  added or removed.

  IMPORTANT: replace "https://www.example.com" below with the real domain
  once one is chosen — every <loc> URL must use the live, final domain.

  After updating, you can submit this file's URL in Google Search Console
  (Sitemaps section) to help Google discover it faster, though it's also
  auto-discovered via the reference in robots.txt.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <url>
    <loc>https://www.example.com/</loc>
    <changefreq>monthly</changefreq>
    <priority>1.0</priority>
  </url>

  <url>
    <loc>https://www.example.com/portfolio.html</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>https://www.example.com/about.html</loc>
    <changefreq>yearly</changefreq>
    <priority>0.5</priority>
  </url>

  <url>
    <loc>https://www.example.com/contact.html</loc>
    <changefreq>yearly</changefreq>
    <priority>0.5</priority>
  </url>

</urlset>
